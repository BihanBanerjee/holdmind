# JWT secret — must exactly match the backend JWT_SECRET_KEY value.
# Used by Next.js middleware to verify session tokens server-side.
# Never prefix with NEXT_PUBLIC_ — this must stay server-side only.
JWT_SECRET=your-jwt-secret-here

# Backend API URL — only set in production when the API lives on a different domain.
# Leave unset for local development; Next.js proxy routes /api/* to localhost:8000.
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
